@startuml name
skinparam classAttributeIconSize 0

abstract class User {
    - String firstName
    - String lastName
    - String username
    - String password
    - String userID
    + login()
    + logout()
}
class Customer {
    - double moneyAvailable
    - boolean hasMembership
    + purchaseTicket()
}

class Organizer {
    + createEvent()
}

class Admin {
    + addMember(User user)
    + viewMember(String identifier)
    + updateMember(String identifier)
    + deleteMember(String identifier)
    + addVenue(Venue venue)
    + viewVenue(String identifier)
    + updateVenue(String identifier)
    + deleteVenue(String identifier)
    + addEvent(Event event)
    + viewEvent(String identifier)
    + updateEvent(String identifier)
    + deleteEvent(String identifier)
}

abstract class Event {
    - String eventID
    - String name
    - String date
    - String time
    - Venue venue
}

class Concert extends Event
class Sport extends Event
class Special extends Event

abstract class Venue {
    - String venueID
    - String name
    - String type
    - int capacity
    - double cost
}

class Arena extends Venue
class Auditorium extends Venue
class Stadium extends Venue
class OpenAir extends Venue

class RunTicketMiner {
    + {static} main(String[] args)
    + displayMainMenu()
}

class DataManager {
    + readCSV(String fileName)
    + writeEventCSV(String fileName)
    + writeCustomerCSV(String fileName)
    + writeVenueCSV(String fileName)
}

class Logger {
    + {static} logAction(String actionDetail)
}

' --- Relationships ---

User <|-- Customer 
User <|-- Organizer
User <|-- Admin

Event o-- Venue
Admin ..> User : manages
Admin ..> Venue : manages
Admin ..> Event : manages

RunTicketMiner ..> DataManager
RunTicketMiner ..> Logger : logs actions
@enduml